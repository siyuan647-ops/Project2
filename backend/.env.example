# LLM Configuration (Kimi K2.5 via OpenAI-compatible API)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL_NAME=kimi-k2.5

# Tavily Search API (optional - get key from https://tavily.com)
TAVILY_API_KEY=

# Polygon.io (optional - when set, replaces yfinance for stock_data tools; see https://polygon.io)
POLYGON_API_KEY=

# PostgreSQL (used by conversation storage + pgvector)
DATABASE_URL=postgresql://finapp:finapp_secret@postgres:5432/financial_platform
